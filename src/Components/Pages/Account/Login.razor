@page "/account/login"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager Navigation
@inject AuthService AuthService

<div class="login-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
    </header>

    <marquee behavior="scroll" direction="right" scrollamount="5" class="marquee-text">
        •°*”˜˜”*°•.???.•°*”˜˜”*°•.???•°*”˜˜”*°•.???.•°*”˜˜”*°•.???•°*”˜˜”*°•.???
    </marquee>

    <main class="d-flex justify-content-center align-items-center min-vh-50">
        <div class="login-form w-100" style="max-width: 400px;">
            <h2 class="text-center mb-4">Login</h2>

            @if (!string.IsNullOrEmpty(FormError))
            {
                <div class="alert alert-danger">@FormError</div>
            }

            <EditForm Model="LoginModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label for="username" class="form-label">Username:</label>
                    <InputText id="username" class="form-control" @bind-Value="LoginModel.Username" />
                    <ValidationMessage For="() => LoginModel.Username" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label">Password:</label>
                    <InputText id="password" type="password" class="form-control" @bind-Value="LoginModel.Password" />
                    <ValidationMessage For="() => LoginModel.Password" />
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-primary">Login</button>
                </div>

                <div class="text-center">
                    <p>Don't have an account? <NavLink href="/account/register" class="text-info">Sign up now</NavLink></p>
                </div>
            </EditForm>
        </div>
    </main>
</div>

@code {
    private LoginRequest LoginModel { get; } = new();
    private string? FormError;

    private void HandleValidSubmit()
    {
        if (AuthService.Login(LoginModel.Username, LoginModel.Password, out var error))
        {
            Navigation.NavigateTo("/petprofile");
        }
        else
        {
            FormError = error;
        }
    }

    private sealed class LoginRequest
    {
        [Required(ErrorMessage = "Please enter username.")]
        public string? Username { get; set; }

        [Required(ErrorMessage = "Please enter your password.")]
        public string? Password { get; set; }
    }
}
