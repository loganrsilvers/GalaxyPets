@page "/closet"
@using GalaxyPets.Models
@inject AuthService AuthService
@inject ClosetService ClosetService
@inject NavigationManager Navigation

<div class="closet-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1 class="text-center">@AuthService.CurrentUsername''s Closet</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to view your closet.</p>
    }
    else
    {
        <main>
            <section class="container closet-section">
                <div class="filters mb-4">
                    <div class="filter-group">
                        <label for="filterType">Filter by Type:</label>
                        <select @onchange="HandleFilterChange" class="form-control" style="max-width: 200px;">
                            <option value="">All Items</option>
                            <option value="hat">Hats</option>
                            <option value="accessory">Accessories</option>
                            <option value="pet">Pet Items</option>
                        </select>
                    </div>
                </div>

                <div class="view-options mb-4">
                    <button class="btn btn-sm btn-primary" @onclick="() => SetGridColumns(3)">3 Column</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => SetGridColumns(5)">5 Column</button>
                </div>

                @if (FilteredItems.Count > 0)
                {
                    <div class="grid @($"grid-{GridColumns}")">
                        @foreach (var item in FilteredItems)
                        {
                            <div class="item card">
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.ItemName">
                                <div class="card-body">
                                    <h5 class="card-title">@item.ItemName</h5>
                                    <p class="card-text">@item.ItemType</p>
                                    <p class="card-text"><small>@item.Quantity owned</small></p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center">No items in your closet yet. Visit the <NavLink href="/shop">Shop</NavLink> to get started!</p>
                }
            </section>
        </main>
    }
</div>

@code {
    private List<Inventory> Items = new();
    private List<Inventory> FilteredItems = new();
    private int GridColumns = 3;
    private string SelectedFilter = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadClosetData();
    }

    private async Task LoadClosetData()
    {
        Items = await ClosetService.GetUserInventoryAsync(AuthService.CurrentUsername ?? "");
        ApplyFilter();
    }

    private void HandleFilterChange(ChangeEventArgs e)
    {
        SelectedFilter = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrEmpty(SelectedFilter))
        {
            FilteredItems = Items;
        }
        else
        {
            FilteredItems = Items.Where(i => i.ItemType == SelectedFilter).ToList();
        }
    }

    private void SetGridColumns(int columns)
    {
        GridColumns = columns;
    }
}
