@page "/adopt"
@using GalaxyPets.Models
@inject AuthService AuthService
@inject PetService PetService
@inject NavigationManager Navigation

<div class="adopt-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1>Welcome, @AuthService.CurrentUsername!</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to adopt a pet.</p>
    }
    else
    {
        <main>
            <section class="adopt-container">
                <h2>Adopt a Pet</h2>
                
                <div class="adoption-form">
                    <div class="form-group">
                        <label for="petName">Pet Name:</label>
                        <input type="text" class="form-control" id="petName" @bind="PetName" placeholder="Name your pet">
                    </div>

                    <div class="form-group">
                        <label for="species">Species:</label>
                        <select class="form-control" id="species" @onchange="HandleSpeciesChange">
                            <option value="jelly">Stardust Jelly</option>
                            <option value="glorbus">Glorbus</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="color">Color:</label>
                        <select class="form-control" id="color" @onchange="HandleColorChange">
                            <option value="lightpurple">Light Purple</option>
                            <option value="blue">Blue</option>
                            <option value="green">Green</option>
                            <option value="darkpurple">Dark Purple</option>
                            <option value="pink">Pink</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="planet">Home Planet:</label>
                        <select class="form-control" id="planet" @bind="SelectedPlanet">
                            <option value="Atom's Halo">Atom's Halo</option>
                            <option value="Galaxy Glitter">Galaxy Glitter</option>
                            <option value="Zero Gravity">Zero Gravity</option>
                            <option value="Orbitors">Orbitors</option>
                        </select>
                    </div>

                    <div class="pet-preview">
                        <h3>Pet Preview:</h3>
                        <img src="@PreviewImageUrl" alt="Your pet" style="width: 200px; height: 200px;">
                        <p>@PreviewDescription</p>
                    </div>

                    <button class="btn btn-primary mt-3" @onclick="AdoptPet">Adopt This Pet!</button>
                </div>
            </section>
        </main>
    }
</div>

@code {
    private string PetName = "";
    private string SelectedSpecies = "jelly";
    private string SelectedColor = "lightpurple";
    private string SelectedPlanet = "Atom's Halo";
    private string PreviewImageUrl = "/img/jelly/regular/lightpurple.png";
    private string PreviewDescription = "Jelly: A translucent jellyfish-like creature that floats through galaxies.";

    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
        }
        UpdatePreview();
    }

    private void HandleSpeciesChange(ChangeEventArgs e)
    {
        SelectedSpecies = e.Value?.ToString() ?? "jelly";
        UpdatePreview();
    }

    private void HandleColorChange(ChangeEventArgs e)
    {
        SelectedColor = e.Value?.ToString() ?? "lightpurple";
        UpdatePreview();
    }

    private void UpdatePreview()
    {
        PreviewImageUrl = $"/img/{SelectedSpecies}/regular/{SelectedColor}.png";
        PreviewDescription = SelectedSpecies == "glorbus"
            ? "Glorbus: A cheerful space blob that feeds on cosmic dust."
            : "Jelly: A translucent jellyfish-like creature that floats through galaxies.";
    }

    private async Task AdoptPet()
    {
        if (string.IsNullOrWhiteSpace(PetName))
        {
            await JSRuntime.InvokeVoidAsync("alert", "Please name your pet!");
            return;
        }

        var newPet = new Pet
        {
            Username = AuthService.CurrentUsername ?? "",
            PetName = PetName,
            Species = SelectedSpecies,
            Color = SelectedColor,
            Expression = "regular",
            Planet = SelectedPlanet,
            Birthday = DateTime.Now
        };

        await PetService.AdoptPetAsync(newPet);
        Navigation.NavigateTo("/petprofile");
    }

    [Inject]
    private IJSRuntime? JSRuntime { get; set; }
}
