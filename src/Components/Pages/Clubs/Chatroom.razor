@page "/clubs/chatroom"
@inject AuthService AuthService
@inject MessageService MessageService
@inject NavigationManager Navigation

<div class="club-chatroom-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to join clubs.</p>
    }
    else
    {
        <main class="container-md">
            <section class="club-chatroom-grid">
                <section class="left-column">
                    <figure>
                        <figcaption>
                            <h2>Club Chatroom</h2>
                        </figcaption>
                        <img src="/img/planets/blueplanet.png" alt="Club">
                    </figure>
                    <section class="club-chatroom-info">
                        <div><p>A place to chat with fellow club members!</p></div>
                    </section>
                </section>
                <section class="right-column">
                    <div class="chatroom-container">
                        <div class="messages-box">
                            @foreach (var msg in Messages)
                            {
                                <div class="message-item">
                                    <strong>@msg.Username:</strong> @msg.Content
                                </div>
                            }
                        </div>
                        <div class="input-box">
                            <input type="text" @bind="NewMessage" placeholder="Type a message..." @onkeyup="HandleKeyPress" class="form-control">
                            <button @onclick="SendMessage" class="btn btn-primary mt-2">Send</button>
                        </div>
                    </div>
                </section>
            </section>
        </main>
    }
</div>

@code {
    private List<ChatMessage> Messages = new();
    private string NewMessage = "";
    private const int ClubId = 0;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        Messages = await MessageService.GetMessagesAsync(ClubId);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(NewMessage))
            return;

        var msg = new ChatMessage
        {
            Username = AuthService.CurrentUsername ?? "Anonymous",
            Content = NewMessage,
            ClubId = ClubId,
            Timestamp = DateTime.Now
        };

        await MessageService.SendMessageAsync(msg);
        NewMessage = "";
        await LoadMessages();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SendMessage();
    }
}
