@page "/petprofile"
@using GalaxyPets.Models
@inject AuthService AuthService
@inject PetService PetService
@inject NavigationManager Navigation

<div class="petprofile-page">
    <header class="border-bottom sticky-top">
        @if (AuthService.IsAuthenticated)
        {
            <div>
                <h2>Welcome, @AuthService.CurrentUsername!</h2>
                <p>Your current points: <strong>@UserPoints</strong></p>
            </div>
        }
        else
        {
            <p><NavLink href="/account/login">Log in</NavLink> to view your pet profile.</p>
        }
    </header>

    @if (AuthService.IsAuthenticated)
    {
        <main>
            <section class="pet-profile">
                @if (CurrentPet != null)
                {
                    <h1>@AuthService.CurrentUsername''s MyGalaxyPet Profile</h1>
                    <div class="pet-info">
                        <div class="pet-image">
                            <div class="alien-container">
                                <img class="alien-image" src="@($"/img/{CurrentPet.Species}/{CurrentPet.Expression}/{CurrentPet.Color}.png")" alt="Your Pet">
                            </div>
                        </div>
                        <div class="pet-details">
                            <h2>@CurrentPet.PetName</h2>
                            <ul>
                                <li><strong>Species:</strong> @CurrentPet.Species</li>
                                <li><strong>Color:</strong> @CurrentPet.Color</li>
                                <li><strong>Home Planet:</strong> @CurrentPet.Planet</li>
                                <li><strong>Birthday:</strong> @CurrentPet.Birthday.ToString("MMM dd, yyyy")</li>
                                <li><strong>Expression:</strong> @CurrentPet.Expression</li>
                            </ul>
                            <blockquote>
                                "i ammm starvinggg for planet pointsss"
                            </blockquote>
                        </div>
                    </div>
                }
                else
                {
                    <h1>No Pet Found</h1>
                    <p>You don't have a pet yet. <NavLink href="/adopt">Adopt one here!</NavLink></p>
                }
            </section>
        </main>
    }
</div>

@code {
    private Pet? CurrentPet;
    private int UserPoints = 0;

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadPetData();
    }

    private async Task LoadPetData()
    {
        CurrentPet = await PetService.GetUserPetAsync(AuthService.CurrentUsername ?? "");
        if (CurrentPet == null)
        {
            CurrentPet = new GalaxyPets.Models.Pet
            {
                PetName = "Stardust Jelly",
                Species = "jelly",
                Color = "lightpurple",
                Expression = "regular",
                Planet = "Atom''s Halo",
                Birthday = DateTime.Now.AddDays(-30)
            };
        }
    }
}
