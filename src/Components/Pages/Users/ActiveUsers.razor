@page "/users/active"
@using GalaxyPets.Models
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="activeusers-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1>Welcome, @AuthService.CurrentUsername!</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to view active users.</p>
    }
    else
    {
        <main>
            <section class="pet-profiles container mt-5">
                <h1>All GalaxyPets Profiles</h1>
                <p class="text-muted">Discover fellow pet owners and their adorable creatures</p>

                @if (AllPets.Count > 0)
                {
                    <div class="row">
                        @foreach (var pet in AllPets)
                        {
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card pet-profile-card">
                                    <div class="card-body">
                                        <h5 class="card-title">@pet.Username''s Pet</h5>
                                        <div class="pet-image-container mb-3">
                                            <img src="@($"/img/{pet.Species}/{pet.Expression}/{pet.Color}.png")" alt="@pet.PetName" class="img-fluid" style="max-width: 200px;">
                                        </div>
                                        <ul class="list-unstyled">
                                            <li><strong>Pet Name:</strong> @pet.PetName</li>
                                            <li><strong>Species:</strong> @pet.Species</li>
                                            <li><strong>Color:</strong> @pet.Color</li>
                                            <li><strong>Planet:</strong> @pet.Planet</li>
                                            <li><strong>Expression:</strong> @pet.Expression</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center text-muted">No pets found yet. <NavLink href="/adopt">Adopt one now!</NavLink></p>
                }
            </section>
        </main>
    }
</div>

@code {
    private List<Pet> AllPets = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadAllPets();
    }

    private async Task LoadAllPets()
    {
        AllPets = await GetAllPetsAsync();
    }

    private async Task<List<Pet>> GetAllPetsAsync()
    {
        await Task.Delay(10);
        return new List<Pet>
        {
            new Pet
            {
                Username = "User1",
                PetName = "Sparkles",
                Species = "jelly",
                Color = "lightpurple",
                Expression = "regular",
                Planet = "Atom''s Halo",
                Birthday = DateTime.Now.AddDays(-60)
            },
            new Pet
            {
                Username = "User2",
                PetName = "Cosmic",
                Species = "glorbus",
                Color = "blue",
                Expression = "sleepy",
                Planet = "Galaxy Glitter",
                Birthday = DateTime.Now.AddDays(-30)
            }
        };
    }
}
