@page "/shop"
@using GalaxyPets.Models
@inject AuthService AuthService
@inject ShopService ShopService
@inject NavigationManager Navigation

<div class="shop-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1 class="text-center">GalaxyPets Shop</h1>
            <p class="text-center">Your Points: <strong>@UserPoints</strong></p>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to shop.</p>
    }
    else
    {
        <main>
            <section class="container shop-section">
                <div class="filters mb-4">
                    <div class="filter-group">
                        <label for="filterType">Filter by Type:</label>
                        <select @onchange="HandleFilterChange" class="form-control" style="max-width: 200px;">
                            <option value="">All Items</option>
                            <option value="hat">Hats</option>
                            <option value="accessory">Accessories</option>
                            <option value="pet-item">Pet Items</option>
                        </select>
                    </div>
                </div>

                <div class="view-options mb-4">
                    <button class="btn btn-sm btn-primary" @onclick="() => SetGridColumns(3)">3 Column</button>
                    <button class="btn btn-sm btn-primary" @onclick="() => SetGridColumns(5)">5 Column</button>
                </div>

                @if (FilteredItems.Count > 0)
                {
                    <div class="grid @($"grid-{GridColumns}")">
                        @foreach (var item in FilteredItems)
                        {
                            <div class="item card">
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name">
                                <div class="card-body">
                                    <h5 class="card-title">@item.Name</h5>
                                    <p class="card-text">@item.ItemType</p>
                                    <p class="card-text"><strong>@item.Price points</strong></p>
                                    <button class="btn btn-sm btn-success" @onclick="() => PurchaseItem(item)">Buy</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-center">No items available.</p>
                }
            </section>
        </main>
    }
</div>

@code {
    private List<Item> Items = new();
    private List<Item> FilteredItems = new();
    private int GridColumns = 3;
    private int UserPoints = 0;
    private string SelectedFilter = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadShopData();
    }

    private async Task LoadShopData()
    {
        Items = await ShopService.GetShopItemsAsync();
        UserPoints = await ShopService.GetUserPointsAsync(AuthService.CurrentUsername ?? "");
        ApplyFilter();
    }

    private void HandleFilterChange(ChangeEventArgs e)
    {
        SelectedFilter = e.Value?.ToString() ?? "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrEmpty(SelectedFilter))
        {
            FilteredItems = Items;
        }
        else
        {
            FilteredItems = Items.Where(i => i.ItemType == SelectedFilter).ToList();
        }
    }

    private void SetGridColumns(int columns)
    {
        GridColumns = columns;
    }

    private async Task PurchaseItem(Item item)
    {
        if (UserPoints >= item.Price)
        {
            await ShopService.PurchaseItemAsync(AuthService.CurrentUsername ?? "", item.Id);
            await LoadShopData();
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "Not enough points to purchase this item.");
        }
    }

    [Inject]
    private IJSRuntime? JSRuntime { get; set; }
}
