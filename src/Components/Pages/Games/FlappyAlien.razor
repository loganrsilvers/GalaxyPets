@page "/games/flappyalien"
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="flappyalien-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1>Welcome, @AuthService.CurrentUsername!</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to play.</p>
    }
    else
    {
        <main>
            <div id="game-area">
                <div class="game-info">
                    <h1>Flappy Alien</h1>
                    <p>Click to make the alien fly!</p>
                </div>
                <canvas width="800" height="600" id="game"></canvas>
            </div>
        </main>
    }
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthService.IsAuthenticated)
        {
            await JSRuntime.InvokeVoidAsync("eval", "fetch(''/js/flappyalien.js'').then(r => r.text()).then(t => eval(t))");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "if(typeof animate !== ''undefined'') cancelAnimationFrame(animate);");
        }
        catch { }
    }

    [Inject]
    private IJSRuntime? JSRuntime { get; set; }
}
