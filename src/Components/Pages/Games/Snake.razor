@page "/games/snake"
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="snake-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1>Welcome, @AuthService.CurrentUsername!</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to play.</p>
    }
    else
    {
        <main>
            <div id="game-area">
                <div class="game-info">
                    <h1>CYBER SNAKE!</h1>
                    <p>Use the ''Arrow Keys'' to move around and eat the planets</p>
                </div>
                <canvas width="400" height="400" id="game"></canvas>
            </div>
        </main>
    }
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthService.IsAuthenticated)
        {
            await JSRuntime.InvokeVoidAsync("eval", "fetch(''/js/snake.js'').then(r => r.text()).then(t => eval(t))");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "if(typeof gameLoop !== ''undefined'') clearInterval(gameLoop);");
        }
        catch { }
    }

    [Inject]
    private IJSRuntime? JSRuntime { get; set; }
}
