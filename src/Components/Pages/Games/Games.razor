@page "/games"
@inject AuthService AuthService
@inject GameService GameService
@inject NavigationManager Navigation

<div class="games-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1 class="text-center">GalaxyPets Games</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to play games.</p>
    }
    else
    {
        <marquee behavior="scroll" direction="left" scrollamount="5" style="color: #17ffee;">
            •°*"˜˜"*°•.???.•°*"˜˜"*°•.???•°*"˜˜"*°•.???.•°*"˜˜"*°•.???•°*"˜˜"*°•.???
        </marquee>

        <main>
            <div class="grid-container">
                <section class="newspaper">
                    <h2>2048</h2>
                    <figure>
                        <NavLink href="/games/2048" class="text-decoration-none">
                            <img src="/img/glorbus/lightpurple.png" alt="lilac glorbus" class="game-icon">
                        </NavLink>
                        <figcaption>featured: lilac glorbus</figcaption>
                    </figure>
                </section>

                <section class="newspaper">
                    <h2>Matching</h2>
                    <figure>
                        <NavLink href="/games/matching" class="text-decoration-none">
                            <img src="/img/jelly/sleepy/blue.png" alt="blue jelly" class="game-icon">
                        </NavLink>
                        <figcaption>featured: blue stardust jelly</figcaption>
                    </figure>
                </section>

                <section class="newspaper">
                    <h2>Flappy Alien</h2>
                    <figure>
                        <NavLink href="/games/flappyalien" class="text-decoration-none">
                            <img src="/img/jelly/ouch/pink.png" alt="pink jelly" class="game-icon">
                        </NavLink>
                        <figcaption>featured: pink stardust jelly</figcaption>
                    </figure>
                </section>

                <section class="newspaper">
                    <h2>Snake</h2>
                    <figure>
                        <NavLink href="/games/snake" class="text-decoration-none">
                            <img src="/img/glorbus/sleepy/green.png" alt="green glorbus" class="game-icon">
                        </NavLink>
                        <figcaption>featured: green sleepy glorbus</figcaption>
                    </figure>
                </section>

                <section class="newspaper">
                    <h2>Connect 4</h2>
                    <figure>
                        <NavLink href="/games/c4" class="text-decoration-none">
                            <img src="/img/glorbus/darkpurple.png" alt="purple glorbus" class="game-icon">
                        </NavLink>
                        <figcaption>featured: purple glorbus</figcaption>
                    </figure>
                </section>
            </div>
        </main>

        <marquee behavior="scroll" direction="right" scrollamount="5" style="color: #17ffee;">
            •°*"˜˜"*°•.???.•°*"˜˜"*°•.???•°*"˜˜"*°•.???.•°*"˜˜"*°•.???•°*"˜˜"*°•.???
        </marquee>
    }
</div>

@code {
    protected override void OnInitialized()
    {
        if (!AuthService.IsAuthenticated)
        {
            Navigation.NavigateTo("/account/login");
        }
    }
}
