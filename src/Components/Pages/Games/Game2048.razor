@page "/games/2048"
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<div class="game2048-page">
    <header class="border-bottom sticky-top">
        <div id="navbar-container"></div>
        @if (AuthService.IsAuthenticated)
        {
            <h1>Welcome, @AuthService.CurrentUsername!</h1>
        }
    </header>

    @if (!AuthService.IsAuthenticated)
    {
        <p class="text-center mt-5"><NavLink href="/account/login">Log in</NavLink> to play.</p>
    }
    else
    {
        <main>
            <div id="game-area">
                <div class="game-info">
                    <h1>2048</h1>
                    <p>Combine the tiles and reach 2048!</p>
                </div>
                <div id="game-container"></div>
            </div>
        </main>
    }
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AuthService.IsAuthenticated)
        {
            await JSRuntime.InvokeVoidAsync("eval", "fetch(''/js/2048.js'').then(r => r.text()).then(t => eval(t))");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "if(typeof game !== ''undefined'') game = null;");
        }
        catch { }
    }

    [Inject]
    private IJSRuntime? JSRuntime { get; set; }
}
